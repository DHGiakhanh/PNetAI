# Server Configuration
HOSTNAME=localhost
PORT=9999

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGO_DIRECT_URI=mongodb://host1.mongodb.net:27017,host2.mongodb.net:27017,host3.mongodb.net:27017/database_name?ssl=true&replicaSet=your_replica_set&authSource=admin&retryWrites=true&w=majority

# JWT
JWT_SECRET=your_jwt_secret_key_here

# Email Configuration (Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@yourapp.com

# Frontend URL
FRONTEND_URL=http://localhost:5173

# PayOS Configuration
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
PAYOS_BASE_URL=https://api-merchant.payos.vn
# Optional: only for partner integration program
PAYOS_PARTNER_CODE=
